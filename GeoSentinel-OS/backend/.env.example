# GeoSentinel OS Backend Configuration

# Database
DATABASE_URL=postgresql://geosentinel:password@localhost/geosentinel_db

# JWT Configuration
JWT_SECRET=your-super-secret-key-change-in-production
AUDIT_HASH_SECRET=your-audit-hash-secret-change-in-production
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Application
ENVIRONMENT=production
SPOOF_DETECTION_ENABLED=true
DEBUG=False
APP_NAME=GeoSentinel OS

# Geofencing
GEOFENCE_RADIUS_METERS=500

# Spoof Detection Thresholds
GPS_JUMP_THRESHOLD_KM=50
UNREALISTIC_SPEED_KMH=200

# File Upload
UPLOAD_DIR=./uploads
MAX_FILE_SIZE_MB=50

# CORS
CORS_ORIGINS=["https://your-frontend-domain.com"]
